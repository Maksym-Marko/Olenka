# =============================================================================
# WordPress Theme — Olenka
# .gitignore
# =============================================================================


# ── Dependencies ─────────────────────────────────────────────────────────────
vendor/
node_modules/


# ── Build Artifacts ──────────────────────────────────────────────────────────
dist/
build/
*.min.css
*.min.js


# ── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example


# ── OS & Editor Files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

.vscode/
.idea/
*.sublime-workspace


# ── Logs & Temp ──────────────────────────────────────────────────────────────
*.log
*.tmp
*.cache
